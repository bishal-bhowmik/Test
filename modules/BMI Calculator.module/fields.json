  {
    "label": "Style",
    "name": "style",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "label": "Background",
        "name": "background",
        "type": "group",
        "children": [
          {
            "label": "Enable",
            "name": "enable",
            "default": false,
            "display": "toggle",
            "type": "boolean"
          },
          {
            "label": "Background Type",
            "name": "background_type",
            "default": "image",
            "display": "select",
            "choices": [
              [
                "image",
                "Image"
              ],
              [
                "gradient",
                "Gradient"
              ],
              [
                "solid_color",
                "Solid Color"
              ]
            ],
            "visibility": {
              "controlling_field_path": "style.background.enable",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "type": "choice"
          },
          {
            "label": "Background Image Position",
            "name": "background_image_position",
            "default": "center",
            "display": "select",
            "choices": [
              [
                "top",
                "Top"
              ],
              [
                "center",
                "Center"
              ],
              [
                "bottom",
                "Bottom"
              ]
            ],
            "visibility_rules": "ADVANCED",
            "advanced_visibility": {
              "boolean_operator": "AND",
              "criteria": [
                {
                  "controlling_field_path": "style.background.background_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "image"
                },
                {
                  "controlling_field_path": "style.background.enable",
                  "operator": "EQUAL",
                  "controlling_value_regex": "true"
                }
              ]
            },
            "type": "choice"
          },
