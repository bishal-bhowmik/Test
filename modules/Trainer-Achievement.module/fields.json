[
  {
    "label": "Content",
    "name": "content",
    "type": "group",
    "expanded": true,
    "children": [
      {
        "label": "Section Title",
        "name": "section_title",
        "default": "<h1>ACHIEVEMENTS</h1>",
        "help_text": "The main heading for the achievements section",
        "type": "richtext"
      }
    ]
  },
  {
    "label": "Counter Stats",
    "name": "counter_stats",
    "type": "group",
    "expanded": true,
    "children": [
      {
        "label": "Counter Items",
        "name": "counter_items",
        "type": "group",
        "occurrence": {
          "min": 1,
          "max": 4,
          "default": 4,
          "sorting_label_field": "counter_stats.counter_items.stat_number"
        },
        "children": [
          {
            "label": "Stat Number",
            "name": "stat_number",
            "default": "<h3>10+</h3>",
            "help_text": "The large number or metric (e.g., 10+, 1k+)",
            "type": "richtext"
          },
          {
            "label": "Stat Label",
            "name": "stat_label",
            "default": "<p>certifications &qulifications</p>",
            "help_text": "The description text below the number",
            "type": "richtext"
          }
        ]
      }
    ]
  },
  {
    "label": "Style",
    "name": "style",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "label": "Background",
        "name": "background",
        "type": "group",
        "children": [
          {
            "label": "Enable",
            "name": "enable",
            "default": false,
            "display": "toggle",
            "type": "boolean"
          },
          {
            "label": "Background Type",
            "name": "background_type",
            "default": "image",
            "display": "select",
            "choices": [
              [
                "image",
                "Image"
              ],
              [
                "gradient",
                "Gradient"
              ],
              [
                "solid_color",
                "Solid Color"
              ]
            ],
            "visibility": {
              "controlling_field_path": "style.background.enable",
              "operator": "EQUAL",
              "controlling_value_regex": "true"
            },
            "type": "choice"
          },
          {
            "label": "Background Image Position",
            "name": "background_image_position",
            "default": "center",
            "display": "select",
            "choices": [
              [
                "top",
                "Top"
              ],
              [
                "center",
                "Center"
              ],
              [
                "bottom",
                "Bottom"
              ]
            ],
            "visibility_rules": "ADVANCED",
            "advanced_visibility": {
              "boolean_operator": "AND",
              "criteria": [
                {
                  "controlling_field_path": "style.background.background_type",
                  "operator": "EQUAL",
                  "controlling_value_regex": "image"
                },
                {
                  "controlling_field_path": "style.background.enable",
                  "operator": "EQUAL",
                  "controlling_value_regex": "true"
                }
              ]
            },
            "type": "choice"
          },
