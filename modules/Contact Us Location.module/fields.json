[
  {
    "label": "Location Details",
    "name": "location_details",
    "type": "group",
    "expanded": true,
    "children": [
      {
        "label": "Location Image",
        "name": "image",
        "default": {
          "src": "../../Images/location.jpg",
          "alt": "Location Image"
        },
        "type": "image"
      },
      {
        "label": "Section Title",
        "name": "title",
        "default": "<h3>New South </br>Wales</h3>",
        "type": "richtext"
      },
      {
        "label": "Full Address",
        "name": "description",
        "default": "42 Glenbrook Street, Parramatta NSW 2150, Australia",
        "type": "richtext"
      },
      {
        "label": "Icon Type",
        "name": "icon_type",
        "choices": [
          [
            "hubspot_icon",
            "Hubspot Icon"
          ],
          [
            "custom_svg",
            "Custom SVG"
          ],
          [
            "image",
            "Image Icon"
          ]
        ],
        "default": "image",
        "help_text": "The image icon will not contain the global color",
        "type": "choice"
      },
      {
        "label": "Hubspot Icon",
        "name": "hubspot_icon",
        "default": {
          "name": "star",
          "type": "SOLID",
          "unicode": "f005"
        },
        "visibility": {
          "controlling_field_path": "location_details.icon_type",
          "operator": "EQUAL",
          "controlling_value_regex": "hubspot_icon"
        },
        "type": "icon"
      },
      {
        "label": "Custom SVG",
        "name": "custom_svg",
        "default": "<svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M14.19 0H5.81C2.17 0 0 2.17 0 5.81V14.18C0 17.83 2.17 20 5.81 20H14.18C17.82 20 19.99 17.83 19.99 14.19V5.81C20 2.17 17.83 0 14.19 0ZM15.35 7.05L13.01 14.59C12.45 16.38 9.94 16.41 9.35 14.63L8.65 12.56C8.46 11.99 8.01 11.53 7.44 11.35L5.36 10.65C3.6 10.06 3.62 7.53 5.41 6.99L12.95 4.64C14.43 4.19 15.82 5.58 15.35 7.05Z\" fill=\"#DAFC00\"/>\n</svg>",
        "visibility": {
          "controlling_field_path": "location_details.icon_type",
          "operator": "EQUAL",
          "controlling_value_regex": "custom_svg"
        },
        "type": "text"
      },
      {
        "label": "Image Icon",
        "name": "image_icon",
        "default": {
          "src": "../../Images/Vector.svg",
          "alt": "Image Icon"
        },
        "visibility": {
          "controlling_field_path": "location_details.icon_type",
          "operator": "EQUAL",
          "controlling_value_regex": "image"
        },
        "type": "image"
      }
    ]
  },
  {
    "label": "Interactive Map",
    "name": "interactive_map",
    "type": "group",
    "expanded": true,
    "children": [
      {
        "label": "Map Title",
        "name": "map_title",
        "default": "<h2>Our Gym Location</h2>",
        "type": "richtext"
      },
      {
        "label": "Map Settings",
        "name": "map_settings",
        "type": "group",
        "expanded": true,
        "children": [
          {
            "label": "How do you want to add the map?",
            "name": "map_type",
            "choices": [
              [
                "embed",
                "Paste Embed Code (HTML)"
              ],
              [
                "address",
                "Type an Address (Auto-generates map)"
              ]
            ],
            "default": "address",
            "type": "choice"
          },
          {
            "label": "Map Embed Code",
            "name": "embed_code",
            "visibility": {
              "controlling_field_path": "interactive_map.map_settings.map_type",
              "operator": "EQUAL",
              "controlling_value_regex": "embed"
            },
            "type": "text"
          },
          {
            "label": "Location Address",
            "name": "map_address",
            "default": "New South Wales, Australia",
            "visibility": {
              "controlling_field_path": "interactive_map.map_settings.map_type",
              "operator": "EQUAL",
              "controlling_value_regex": "address"
            },
            "type": "text"
          }
        ]
      }
    ]
  },
