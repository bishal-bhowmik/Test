[
  {
    "label": "Content",
    "name": "content",
    "type": "group",
    "expanded": false,
    "children": [
      {
        "label": "Section Title",
        "name": "section_title",
        "default": "<h2>Qualifications & certifications</h2>",
        "type": "richtext"
      }
    ]
  },
  {
    "label": "Qualification Section",
    "name": "qualification_section",
    "type": "group",
    "expanded": true,
    "children": [
      {
        "label": "Qualification Item",
        "name": "qualification_item",
        "type": "group",
        "expanded": true,
        "occurrence": {
          "default": 4
        },
        "children": [
          {
            "label": "Icon Type",
            "name": "icon_type",
            "choices": [
              [
                "hubspot_icon",
                "Hubspot Icon"
              ],
              [
                "custom_svg",
                "Custom SVG"
              ],
              [
                "image",
                "Image Icon"
              ]
            ],
            "default": "image",
            "help_text": "The image icon will not contain the global color",
            "type": "choice"
          },
          {
            "label": "Hubspot Icon",
            "name": "hubspot_icon",
            "default": {
              "name": "star",
              "type": "SOLID",
              "unicode": "f005"
            },
            "visibility": {
              "controlling_field": "qualification_section.qualification_item.icon_type",
              "operator": "EQUAL",
              "controlling_value_regex": "hubspot_icon"
            },
            "type": "icon"
          },
          {
            "label": "Custom SVG",
            "name": "custom_svg",
            "default": "<svg class=\"icon\" aria-hidden=\"true\" viewBox=\"0 0 512 512\"> <path d=\"M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm0 448c-110.5 0-200-89.5-200-200S145.5 56 256 56s200 89.5 200 200-89.5 200-200 200zm61.8-104.4l-84.9-61.7c-3.1-2.3-4.9-5.9-4.9-9.7V116c0-6.6 5.4-12 12-12h32c6.6 0 12 5.4 12 12v141.7l66.8 48.6c5.4 3.9 6.5 11.4 2.6 16.8L334.6 349c-3.9 5.3-11.4 6.5-16.8 2.6z\" /> </svg>",
            "placeholder": "Enter SVG Code",
            "visibility": {
              "controlling_field": "qualification_section.qualification_item.icon_type",
              "operator": "EQUAL",
              "controlling_value_regex": "custom_svg"
            },
            "type": "text"
          },
          {
            "label": "Image Icon",
            "name": "image_icon",
            "default": {
              "src": "../../Images/Vector.svg",
              "alt": "Image Icon"
            },
            "visibility": {
              "controlling_field": "qualification_section.qualification_item.icon_type",
              "operator": "EQUAL",
              "controlling_value_regex": "image"
            },
            "type": "image"
          },
          {
            "label": "Qualification",
            "name": "qualification",
            "default": "<p>Strength Training</p>",
            "type": "richtext"
          }
        ]
      }
    ]
  },
  {
    "label": "Gallery Section",
    "name": "gallery_section",
    "type": "group",
    "expanded": true,
    "children": [
      {
        "label": "Gallery Item",
        "name": "gallery_item",
        "type": "group",
        "expanded": true,
        "occurrence": {
          "default": 3,
          "max": 3
